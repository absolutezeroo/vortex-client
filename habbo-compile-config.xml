<?xml version="1.0" encoding="utf-8"?>
<flex-config xmlns="http://www.adobe.com/2006/flex-config">
    <swf-version>35</swf-version>
    <compiler>
        <allow-source-path-overlap>true</allow-source-path-overlap>
        <source-path>
            <path-element>src</path-element>
            <path-element>src/generated</path-element>
        </source-path>
        <optimize>true</optimize>
        <omit-trace-statements>false</omit-trace-statements>
        <strict>true</strict>
    </compiler>
    <output>bin/Habbo.swf</output>
    <file-specs>
        <path-element>src/HabboAir.as</path-element>
    </file-specs>
</flex-config>
