{
	"type": "app",
	"config": "air",
	"mainClass": "HabboAir",
	"additionalOptions":[
		"-default-background-color=#000000",
		"-omit-trace-statements=false"
	],
	"compilerOptions": {
		"source-path": [
			"src/",
			"src/generated/"
		],
		"allow-source-path-overlap": true,
		"output": "bin/Habbo.swf",
		"optimize": true,
		"strict": false,
		"swf-version": 35
	}
}
